---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import '../styles/global.css';
import 'katex/dist/katex.min.css';

interface Props {
  title?: string;
  description?: string;
  pageType?: 'default' | 'post';
}

const {
  title = "Harry's Blog",
  description = 'Public logbook for code, experiments, and long-form notes.',
  pageType = 'default'
} = Astro.props;

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#eef2ea" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/img/favicon.ico" />
    <title>{title}</title>
  </head>
  <body data-page-type={pageType}>
    <div class="page-shell">
      <Header />
      <main class="page-main">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
