---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

const formatter = new Intl.DateTimeFormat('zh-CN', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const visiblePosts = posts.slice(0, 5);
const tags = [...new Set(posts.flatMap((post) => post.data.tags))].sort((a, b) => a.localeCompare(b, 'zh-CN'));
const earliestPostLabel = posts.length > 0 ? formatter.format(posts[posts.length - 1].data.date) : null;
---

<BaseLayout
  title="Harry's Blog"
  description="代码、研究与阅读笔记。"
>
  <section class="home-intro">
    <p class="home-intro__kicker">Harry's Blog</p>
    <h1>代码、研究与阅读笔记。</h1>
    <p class="home-intro__lede">
      这里会发布技术文章、实验记录，以及一些值得慢慢写下来的长文。
    </p>
  </section>

  {posts.length > 0 ? (
    <>
      <section class="section-block">
        <div class="section-heading">
          <h2>最近文章</h2>
        </div>

        <div class="post-grid-list">
          {visiblePosts.map((post, index) => (
            <PostCard post={post} featured={index === 0} />
          ))}
        </div>
      </section>

      {earliestPostLabel && (
        <section class="section-block">
          <div class="section-heading">
            <h2>站点概览</h2>
          </div>
          <dl class="site-summary">
            <div>
              <dt>公开文章</dt>
              <dd>{posts.length}</dd>
            </div>
            <div>
              <dt>最早一篇</dt>
              <dd>{earliestPostLabel}</dd>
            </div>
            <div>
              <dt>标签数量</dt>
              <dd>{tags.length}</dd>
            </div>
          </dl>
        </section>
      )}
    </>
  ) : (
    <section class="empty-state">
      <h2>还没有公开文章</h2>
      <p>第一篇文章会出现在这里。</p>
    </section>
  )}
</BaseLayout>
